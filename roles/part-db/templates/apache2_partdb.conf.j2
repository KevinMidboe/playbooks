<VirtualHost *:80>
  ServerName part-db.schleppe
  DocumentRoot {{ partdb_directory }}/public

  <FilesMatch \\.php$>
    SetHandler application/x-httpd-php
  </FilesMatch>

  DirectoryIndex disabled
  DirectoryIndex index.php index.html

  <Directory {{ partdb_directory }}/public>
    Options -Indexes
    AllowOverride All
    Require all granted
  </Directory>
</VirtualHost>
