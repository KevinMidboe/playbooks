# Part-DB .env.local template

APP_ENV=prod
APP_SECRET=SomeRandomSecretKey123
DATABASE_URL={{ partdb_database_url }}?serverVersion=17.6&sslMode=disable

# Optional: configure currency
BASE_CURRENCY=EUR
DEFAULT_LANG=en
DEFAULT_TIMEZONE=Europe/Berlin

# Logging
LOG_LEVEL=debug

# Web interface
PARTDB_WEB_TITLE=Part-DB
PARTDB_WEB_THEME=default

# Unused, but required
DATABASE_MYSQL_USE_SSL_CA=0
DATABASE_MYSQL_SSL_VERIFY_CERT=0
SAML_ENABLED=0
